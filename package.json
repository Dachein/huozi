{
  "name": "huozi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:build": "npx @opennextjs/cloudflare build",
    "cf:preview": "npx @opennextjs/cloudflare dev",
    "cf:deploy:web": "npx @opennextjs/cloudflare build && npx @opennextjs/cloudflare deploy",
    "cf:deploy:api": "pnpm -C packages/huozi-cloud cf:deploy:api",
    "cf:deploy:all": "pnpm cf:deploy:api && pnpm cf:deploy:web",
    "cf:deploy": "echo '\\nUse one of: cf:deploy:api (backend) | cf:deploy:web (frontend) | cf:deploy:all\\n' && exit 1",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.4-alpha24",
    "@heroicons/react": "^2.2.0",
    "echarts": "^6.0.0",
    "jose": "^6.2.2",
    "lodash": "^4.18.1",
    "lucide-react": "^1.8.0",
    "marked": "^16.4.2",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-responsive-carousel": "^3.2.23",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "~4.85.0"
  }
}
